# Front-end build configuration (Vite). Copy to `.env.local` and adjust.
#
# Base URL of the VANGO API server, without a trailing slash.
# Defaults to http://localhost:3001 when unset.
# Production builds must use an https:// URL (or a same-origin path like /api);
# plain http:// is rejected at runtime so credentials are never sent in the clear.
VITE_API_BASE=http://localhost:3001
