JWT_SECRET=change_this_to_a_long_random_string
PORT=3001

# Secret used to HMAC-sign stamp tokens (>= 32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STAMP_SIGNING_SECRET=change_this_to_a_long_random_string

# Accept bare, unsigned stamp codes (e.g. DAVID01) in addition to signed tokens.
# Defaults to true so ALREADY-PRINTED QR codes keep working.
# Setting this to false enforces signed tokens and REQUIRES reprinting every QR
# code from `node scripts/generate-stamp-urls.js` first.
ALLOW_LEGACY_STAMP_CODES=true
